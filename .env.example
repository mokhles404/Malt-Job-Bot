# --- Malt Bot Configuration ---
# Copy this file to .env and fill in your values

# Your preferred daily rate in EUR
PREFERRED_DAILY_RATE=500

# Maximum applications per single bot run
MAX_APPLICATIONS_PER_RUN=5

# Maximum applications per day (across all runs)
MAX_APPLICATIONS_PER_DAY=10

# Run in headless mode (true for production, false for debugging)
HEADLESS=true

# Browser: unset defaults to "chrome" (installed Google Chrome — less bot detection than bundled Chromium).
# Use empty, chromium, bundled, or playwright to force Playwright's Chromium instead.
PLAYWRIGHT_CHANNEL=chrome

# Optional: attach to Chrome you start manually with remote debugging instead of launching a browser.
# Example (macOS): /Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome \
#   --remote-debugging-port=9222 --user-data-dir="$PWD/chrome-malt-profile"
# Then set: CHROME_CDP_URL=http://127.0.0.1:9222
CHROME_CDP_URL=

# Optional: OpenAI API key for LLM-powered cover letters (leave empty to use templates)
OPENAI_API_KEY=
